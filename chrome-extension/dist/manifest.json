{
  "manifest_version": 3,
  "name": "GitHub RAG Code Analyzer",
  "version": "1.0.0",
  "description": "Chat with any GitHub file using AI-powered RAG",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "index.html",
    "default_title": "GitHub Code Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": ["activeTab", "scripting", "storage", "tabs"],

  "host_permissions": [
    "https://github.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
